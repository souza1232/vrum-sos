# Copie este arquivo para .env.local e preencha com seus dados do Supabase
# Acesse: https://supabase.com/dashboard → seu projeto → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Email do admin inicial (será criado manualmente no Supabase)
ADMIN_EMAIL=admin@vrumsos.com.br
